# =====================================================
# Nanum_User .dockerignore
# Docker 빌드 컨텍스트에서 제외할 파일/디렉토리
# 불필요한 파일 제외로 빌드 속도 향상 및 이미지 크기 최소화
# =====================================================

# 의존성 폴더 (Docker 내에서 npm ci로 재설치)
node_modules

# 이전 빌드 결과물
dist

# 환경변수 파일 (빌드 인자로 주입)
.env
.env.local
.env.*.local

# 로컬 설정 파일
*.local

# Git 관련
.git
.gitignore
.gitattributes

# 문서
README.md

# IDE 설정
.idea
.vscode
*.code-workspace

# 로그 파일
*.log
npm-debug.log*

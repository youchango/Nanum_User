# [의존성] 라이브러리 폴더 (용량이 매우 크므로 제외)
node_modules/
dist/
dist-ssr/
*.local

# [보안] 환경 변수 파일 (API 주소, 포트 등 민감 정보 - 절대 올리면 안 됨!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# [로그] 실행 및 에러 로그
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# [IDE/시스템] 작업 환경 설정 및 OS 임시 파일
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# [기타] 빌드 결과물 및 캐시
.cache/
.parcel-cache/
.eslintcache

# [배포] Docker / Nginx (로컬 설정)
